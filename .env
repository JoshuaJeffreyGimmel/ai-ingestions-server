# OpenWebUI
OPENAI_API_BASE_URL=http://litellm:4000/v1
WEBUI_OPENAI_API_KEY=any_random_string_works_here
WEBUI_SECRET_KEY=replace_this_with_a_long_random_string

# LiteLLM
LITELLM_MASTER_KEY=sk-master-key-replace-me

# db
POSTGRES_DB=litellm
POSTGRES_USER=llmproxy
POSTGRES_PASSWORD=generate_a_secure_db_password_here
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# External AI Provider Keys (For LiteLLM to use)
OPENAI_API_KEY=sk-proj-your-actual-openai-key-here
